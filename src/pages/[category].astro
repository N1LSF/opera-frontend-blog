---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch(`
    *[_type == "category"]{
      "slug": slug.current,
      title,
      description,
      pageLayout
    }
  `);

  return categories.map((cat: any) => ({
    params: { category: cat.slug },
    props: {
      title: cat.title,
      description: cat.description || '',
      pageLayout: cat.pageLayout || 'simple',
    },
  }));
}

const { category } = Astro.params;
const { title, description, pageLayout } = Astro.props;

const baseFilter = `_type == "post" && !(_id in path("drafts.**")) && (
  category->slug.current == "${category}" ||
  "${category}" in categories[]->slug.current
)`;

let posts: any[];
if (pageLayout === 'simple') {
  posts = await sanityClient.fetch(`*[${baseFilter}] | order(publishedAt desc){
    title, slug, publishedAt, "authorName": author->name, mainImage
  }`);
} else {
  posts = await sanityClient.fetch(`*[${baseFilter}] | order(publishedAt desc){
    title, slug, mainImage, "composerName": composer->name, "countryName": country->title, "eraTitle": era->title
  }`);
}

let countries: any[] = [];
let eras: any[] = [];
let composers: any[] = [];
if (pageLayout === 'filters') {
  [countries, eras, composers] = await Promise.all([
    sanityClient.fetch(`*[_type == "country"] | order(title asc){ title }`),
    sanityClient.fetch(`*[_type == "era"] | order(title asc){ title }`),
    sanityClient.fetch(`*[_type == "composer"] | order(name asc){ name }`),
  ]);
}
---

<MainLayout title={title}>
  <main class="content">
    <div class="page-header">
      <h1 class="page-title">{title}</h1>
      {description && <p class="page-subtitle">{description}</p>}
    </div>

    {/* ===== SIMPLE: карточки статей с поиском ===== */}
    {pageLayout === 'simple' && (
      <>
        {posts.length > 0 && (
          <div style="position: relative; margin-bottom: 40px; max-width: 100%;">
            <svg width="20" height="20" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #aaa; pointer-events: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="pageSearch" class="page-search-input" placeholder="Поиск по статьям рубрики..." autocomplete="off">
          </div>
        )}

        {posts.length > 0 ? (
          <div class="articles-grid" id="articlesGrid">
            {posts.map((post: any) => (
              <article class="article-card">
                {post.mainImage && (
                  <a href={`/blog/${post.slug?.current || '#'}/`}>
                    <div class="article-image">
                      <img src={urlFor(post.mainImage).width(400).height(260).auto('format').url()} alt={post.title} loading="lazy" />
                    </div>
                  </a>
                )}
                <div class="article-body">
                  <h3 class="article-title"><a href={`/blog/${post.slug?.current || '#'}/`}>{post.title}</a></h3>
                  <div class="article-footer" style="display: flex; justify-content: space-between;">
                    <span>{post.authorName || 'Редакция'}</span>
                    <span>{new Date(post.publishedAt).toLocaleDateString('ru-RU')}</span>
                  </div>
                </div>
              </article>
            ))}
            <div class="no-results" id="noResults" style="display: none; grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted); font-size: 1.2rem;">
              По вашему запросу ничего не найдено
            </div>
          </div>
        ) : (
          <div class="no-posts-container">
            <p class="no-posts">В этой рубрике пока нет статей.</p>
          </div>
        )}
      </>
    )}

    {/* ===== CARDS: карточки с тегами ===== */}
    {pageLayout === 'cards' && (
      <>
        {posts.length > 0 ? (
          <div class="plots-grid">
            {posts.map((post: any) => (
              <article class="plot-card">
                <a href={`/blog/${post.slug?.current || '#'}/`}>
                  {post.mainImage ? (
                    <img class="plot-img" src={urlFor(post.mainImage).width(600).height(400).auto('format').url()} alt={post.title} loading="lazy" />
                  ) : (
                    <div class="plot-img" style="background: #eee;"></div>
                  )}
                  <div class="plot-info">
                    <h2 class="plot-title">{post.title}</h2>
                    <div class="plot-tags">
                      {post.composerName && <span>{post.composerName}</span>}
                      {post.countryName && <span>{post.countryName}</span>}
                      {post.eraTitle && <span>{post.eraTitle}</span>}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="no-posts-container">
            <p class="no-posts">В этой рубрике пока нет статей.</p>
          </div>
        )}
      </>
    )}

    {/* ===== FILTERS: карточки с фильтрами ===== */}
    {pageLayout === 'filters' && (
      <>
        {posts.length > 0 ? (
          <div class="plots-wrapper">
            <div class="filters-panel">
              <div class="filter-group search-group">
                <label for="textSearch">Поиск по названию</label>
                <div class="search-input-wrapper">
                  <svg class="search-icon-small" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  </svg>
                  <input type="text" id="textSearch" class="filter-search-input" placeholder="Например: Кармен, Аида..." autocomplete="off">
                </div>
              </div>
              <div class="filter-group">
                <label for="countryFilter">Страна</label>
                <select id="countryFilter" class="filter-select">
                  <option value="all">Все страны</option>
                  {countries.map((c: any) => ( <option value={c.title}>{c.title}</option> ))}
                </select>
              </div>
              <div class="filter-group">
                <label for="eraFilter">Эпоха</label>
                <select id="eraFilter" class="filter-select">
                  <option value="all">Все эпохи</option>
                  {eras.map((e: any) => ( <option value={e.title}>{e.title}</option> ))}
                </select>
              </div>
              <div class="filter-group">
                <label for="composerFilter">Композитор</label>
                <select id="composerFilter" class="filter-select">
                  <option value="all">Все композиторы</option>
                  {composers.map((c: any) => ( <option value={c.name}>{c.name}</option> ))}
                </select>
              </div>
            </div>

            <div class="plots-grid" id="plotsGrid">
              {posts.map((post: any) => (
                <article class="plot-card" data-country={post.countryName || 'none'} data-era={post.eraTitle || 'none'} data-composer={post.composerName || 'none'}>
                  <a href={`/blog/${post.slug?.current || '#'}/`}>
                    {post.mainImage ? (
                      <img class="plot-img" src={urlFor(post.mainImage).width(600).height(400).auto('format').url()} alt={post.title} loading="lazy" />
                    ) : (
                      <div class="plot-img" style="background: #eee;"></div>
                    )}
                    <div class="plot-info">
                      <h2 class="plot-title">{post.title}</h2>
                      <div class="plot-tags">
                        {post.composerName && <span>{post.composerName}</span>}
                        {post.countryName && <span>{post.countryName}</span>}
                        {post.eraTitle && <span>{post.eraTitle}</span>}
                      </div>
                    </div>
                  </a>
                </article>
              ))}
              <div class="no-posts-container" id="noResults" style="display: none; grid-column: 1 / -1; margin-top: 20px;">
                <p class="no-posts">По вашему запросу ничего не найдено</p>
                <p style="font-size: 0.9rem; color: #999; margin-top: 10px;">Попробуйте очистить фильтры или ввести другое название.</p>
              </div>
            </div>
          </div>
        ) : (
          <div class="no-posts-container">
            <p class="no-posts">В этой рубрике пока нет статей.</p>
          </div>
        )}
      </>
    )}
  </main>
</MainLayout>

<style>
    /* БАЗОВЫЕ СТИЛИ */
    .content { padding: 40px 60px; }
    .page-header { margin-bottom: 30px; }
    .page-title { font-family: var(--font-head); font-size: 2.5rem; margin-bottom: 15px; }
    .page-subtitle { color: var(--text-muted); }

    .no-posts-container { background: #fff; padding: 40px; border-radius: var(--radius-lg); text-align: center; border: 1px dashed #ccc; }
    .no-posts { font-size: 1.2rem; color: var(--text-muted); font-weight: 500; }

    /* === SIMPLE: article-card === */
    .page-search-input { width: 100%; padding: 16px 16px 16px 48px; border: 1px solid rgba(0,0,0,0.1); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 1.05rem; color: var(--text-main); outline: none; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
    .page-search-input:focus { border-color: var(--accent-primary); box-shadow: 0 10px 25px rgba(128, 37, 37, 0.08); }

    .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; }
    .article-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: 0.3s; display: flex; flex-direction: column; }
    .article-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .article-image { height: 220px; overflow: hidden; }
    .article-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .article-card:hover .article-image img { transform: scale(1.05); }
    .article-body { padding: 30px; display: flex; flex-direction: column; flex-grow: 1; }
    .article-title { font-family: var(--font-head); font-size: 1.4rem; margin-bottom: 15px; line-height: 1.3; }
    .article-title a { color: var(--text-main); transition: color 0.2s; }
    .article-title a:hover { color: var(--accent-primary); }
    .article-footer { margin-top: auto; font-size: 0.85rem; color: var(--text-muted); padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); }

    /* === CARDS + FILTERS: plot-card === */
    .plots-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; }
    .plot-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft); transition: 0.3s; }
    .plot-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .plot-img { width: 100%; height: 200px; object-fit: cover; }
    .plot-info { padding: 24px; }
    .plot-title { font-family: var(--font-head); font-size: 1.2rem; margin-bottom: 12px; color: var(--text-main); transition: 0.2s; }
    .plot-card:hover .plot-title { color: var(--accent-primary); }
    .plot-tags { font-size: 0.8rem; color: var(--accent-primary); font-weight: 500; display: flex; flex-wrap: wrap; gap: 8px; }
    .plot-tags span { background: var(--accent-light); padding: 4px 10px; border-radius: 50px; }

    /* === FILTERS panel === */
    .filters-panel { background: var(--bg-card); padding: 20px; border-radius: var(--radius-lg); display: flex; gap: 20px; margin-bottom: 40px; box-shadow: var(--shadow-soft); flex-wrap: wrap; }
    .filter-group { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 200px; }
    .search-group { flex-basis: 100%; }
    .search-input-wrapper { position: relative; }
    .search-icon-small { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #aaa; pointer-events: none; }
    .filter-search-input { width: 100%; padding: 12px 12px 12px 38px; border: 1px solid #E0E0E0; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 1rem; color: var(--text-main); outline: none; transition: 0.2s; }
    .filter-search-input:focus { border-color: var(--accent-primary); }
    .filter-group label { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; }
    .filter-select { padding: 12px; border: 1px solid #E0E0E0; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 1rem; color: var(--text-main); background-color: var(--bg-body); cursor: pointer; outline: none; }
    .filter-select:focus { border-color: var(--accent-primary); }

    /* === АДАПТИВ === */
    @media (max-width: 1000px) {
        .content { padding: 30px 20px; }
    }

    @media (max-width: 768px) {
        .content { padding: 20px 15px; }
        .page-header { margin-bottom: 25px; }
        .page-title { font-size: 2rem; margin-bottom: 10px; line-height: 1.2; }
        .page-subtitle { font-size: 0.95rem; }

        .page-search-input { padding: 14px 14px 14px 44px; font-size: 16px; border-radius: 12px; }
        .articles-grid { grid-template-columns: 1fr; gap: 20px; }
        .article-image { height: 200px; }
        .article-body { padding: 20px; }
        .article-title { font-size: 1.3rem; }

        .plots-grid { grid-template-columns: 1fr; gap: 20px; }
        .plot-info { padding: 20px; }
        .plot-title { font-size: 1.3rem; }

        .filters-panel { padding: 15px; gap: 15px; margin-bottom: 30px; border-radius: 16px; }
        .filter-group { flex-basis: 100%; min-width: 100%; }
        .filter-search-input, .filter-select { padding: 14px; font-size: 16px; border-radius: 12px; }
        .filter-search-input { padding-left: 40px; }
    }
</style>

<script>
    function initCategoryPage() {
        // Simple layout: text search
        const pageSearch = document.getElementById('pageSearch') as HTMLInputElement;
        if (pageSearch) {
            const cards = document.querySelectorAll('.article-card');
            const noResultsMsg = document.getElementById('noResults');
            pageSearch.addEventListener('input', () => {
                const query = pageSearch.value.toLowerCase().trim();
                let visibleCount = 0;
                cards.forEach(card => {
                    const title = card.querySelector('.article-title')?.textContent?.toLowerCase() || '';
                    if (title.includes(query)) {
                        (card as HTMLElement).style.display = 'flex';
                        visibleCount++;
                    } else {
                        (card as HTMLElement).style.display = 'none';
                    }
                });
                if (noResultsMsg) {
                    noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
                }
            });
        }

        // Filters layout: dropdowns + search
        const textSearch = document.getElementById('textSearch') as HTMLInputElement;
        const countryFilter = document.getElementById('countryFilter') as HTMLSelectElement;
        const eraFilter = document.getElementById('eraFilter') as HTMLSelectElement;
        const composerFilter = document.getElementById('composerFilter') as HTMLSelectElement;

        if (textSearch && countryFilter) {
            const plotCards = document.querySelectorAll('.plot-card');
            const noResults = document.getElementById('noResults');

            function filterPosts() {
                const selectedCountry = countryFilter.value;
                const selectedEra = eraFilter.value;
                const selectedComposer = composerFilter.value;
                const searchQuery = textSearch.value.toLowerCase().trim();
                let visibleCount = 0;

                plotCards.forEach(card => {
                    const el = card as HTMLElement;
                    const matchCountry = selectedCountry === 'all' || el.dataset.country === selectedCountry;
                    const matchEra = selectedEra === 'all' || el.dataset.era === selectedEra;
                    const matchComposer = selectedComposer === 'all' || el.dataset.composer === selectedComposer;
                    const title = card.querySelector('.plot-title')?.textContent?.toLowerCase() || '';
                    const matchText = title.includes(searchQuery);

                    if (matchCountry && matchEra && matchComposer && matchText) {
                        el.style.display = 'block';
                        visibleCount++;
                    } else {
                        el.style.display = 'none';
                    }
                });

                if (noResults) {
                    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
                }
            }

            textSearch.addEventListener('input', filterPosts);
            countryFilter.addEventListener('change', filterPosts);
            eraFilter.addEventListener('change', filterPosts);
            composerFilter.addEventListener('change', filterPosts);
        }
    }

    initCategoryPage();
    document.addEventListener('astro:after-swap', initCategoryPage);
</script>
