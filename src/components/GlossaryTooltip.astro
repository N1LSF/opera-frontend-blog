import {defineField, defineType} from 'sanity'

export default defineType({
  name: 'glossaryTerm',
  title: 'Глоссарий',
  type: 'document',
  fields: [
    defineField({
      name: 'term',
      title: 'Термин / Имя',
      type: 'string',
      validation: (Rule) => Rule.required(),
    }),
    defineField({
      name: 'slug',
      title: 'Slug (URL)',
      type: 'slug',
      options: { source: 'term', maxLength: 96 },
      validation: (Rule) => Rule.required(),
    }),
    defineField({
      name: 'termType',
      title: 'Тип записи',
      type: 'string',
      options: {
        list: [
          { title: 'Термин', value: 'term' },
          { title: 'Либреттист', value: 'librettist' },
          { title: 'Опера', value: 'opera' },
          { title: 'Имя', value: 'person' },
        ],
        layout: 'radio',
      },
      validation: (Rule) => Rule.required(),
    }),
    defineField({
      name: 'definition',
      title: 'Краткое определение (для тултипа)',
      description: 'Короткий текст — появится при наведении на термин в статье',
      type: 'text',
      rows: 3,
      validation: (Rule) => Rule.required(),
    }),
    defineField({
      name: 'linkedPost',
      title: 'Ссылка на статью',
      description: 'Для либреттистов и опер — ссылка на подробную статью в рубрике',
      type: 'reference',
      to: [{ type: 'post' }],
    }),
  ],
  preview: {
    select: {
      title: 'term',
      subtitle: 'termType',
    },
    prepare({ title, subtitle }) {
      const labels: Record<string, string> = {
        term: 'Термин',
        librettist: 'Либреттист',
        opera: 'Опера',
        person: 'Имя',
      }
      return {
        title,
        subtitle: labels[subtitle] || subtitle,
      }
    },
  },
  orderings: [
    {
      title: 'По алфавиту',
      name: 'termAsc',
      by: [{ field: 'term', direction: 'asc' }],
    },
  ],
})