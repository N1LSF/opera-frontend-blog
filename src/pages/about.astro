---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import { PortableText } from 'astro-portabletext';

const about = await sanityClient.fetch(`*[_type == "aboutPage"][0]{
  pageTitle,
  photo,
  body
}`);
---

<MainLayout title="О блоге">
    <main class="content">
        <div class="about-container">
            <h1 class="page-title">{about?.pageTitle || 'О проекте «Читая Оперу»'}</h1>
            
            <div class="about-card">
                <div class="about-image">
                    {about?.photo ? (
                        <img src={urlFor(about.photo).width(1000).height(400).auto('format').url()} alt="Фото автора" class="about-photo" />
                    ) : (
                        <div class="image-placeholder"></div>
                    )}
                </div>
                
                <div class="about-text">
                    {about?.body && about.body.length > 0 ? (
                        <PortableText value={about.body} />
                    ) : (
                        <p class="lead-text">Добро пожаловать в блог, где опера перестает быть скучной классикой и превращается в захватывающий сериал.</p>
                        <p>Идея этого проекта родилась из желания показать, что скрывается за красивыми декорациями и сложными вокальными партиями.</p>
                        <p>Наталья, напишите текст в панели управления Sanity → «Страница О блоге»</p>
                    )}
                </div>
            </div>
        </div>
    </main>
</MainLayout>

<style>
    /* БАЗОВЫЕ СТИЛИ (ДЕСКТОП) */
    .content { padding: 40px 60px; max-width: 1000px; margin: 0 auto; }
    .page-title { font-family: var(--font-head); font-size: 2.8rem; margin-bottom: 40px; text-align: center; }
    
    .about-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.05)); display: flex; flex-direction: column; }
    
    .about-image { height: 300px; background: var(--accent-light); position: relative; }
    .image-placeholder { width: 100%; height: 100%; background: linear-gradient(45deg, var(--accent-light), #e3d1d1); display: flex; align-items: center; justify-content: center; }
    .image-placeholder::after { content: 'Фото :з'; color: var(--accent-primary); font-family: var(--font-head); font-size: 1.5rem; opacity: 0.5; }
    
    .about-text { padding: 50px; font-size: 1.1rem; line-height: 1.8; color: var(--text-main); }
    .lead-text { font-size: 1.3rem; font-family: var(--font-head); color: var(--accent-primary); margin-bottom: 20px; font-style: italic; }
    .about-text p { margin-bottom: 20px; }
    
    .about-list { margin-left: 20px; margin-bottom: 20px; color: var(--text-muted); }
    /* Возвращаем стандартные кружочки списку только для этого блока */
    .about-list li { list-style-type: disc !important; margin-bottom: 10px; display: list-item !important; }

    /* === АДАПТИВ ДЛЯ МОБИЛЬНЫХ ТЕЛЕФОНОВ И ПЛАНШЕТОВ === */
    @media (max-width: 1000px) {
        .content { padding: 30px 20px; }
        .about-text { padding: 35px; }
    }

    @media (max-width: 768px) {
        .content { padding: 20px 15px; } /* Расширяем область до краев экрана */
        
        .page-title { 
            font-size: 2rem; /* Уменьшаем огромный заголовок */
            margin-bottom: 25px; 
            line-height: 1.2;
        }
        
        .about-image { 
            height: 200px; /* Делаем картинку пониже, чтобы текст влез на первый экран */
        }
        
        .about-text { 
            padding: 20px; /* Убираем гигантские отступы, чтобы текст не был узкой сосиской */
            font-size: 1rem; /* Чуть уменьшаем шрифт для мобилки */
        }
        
        .lead-text { 
            font-size: 1.15rem; /* Уменьшаем лид-абзац */
            line-height: 1.5;
        }

        .about-list {
            margin-left: 15px; /* Придвигаем список чуть левее */
        }
        .about-photo { width: 100%; height: 100%; object-fit: cover; }
    }
</style>