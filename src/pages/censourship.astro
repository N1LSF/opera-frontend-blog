---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

const posts = await sanityClient.fetch(`*[_type == "post" && !(_id in path("drafts.**")) && "history" in categories[]->slug.current] | order(publishedAt desc){
  title,
  slug,
  publishedAt,
  "authorName": author->name,
  mainImage
}`);
---

<MainLayout title="История создания">
    <main class="content">
        <div class="page-header">
            <h1 class="page-title">История создания</h1>
            <p style="color: var(--text-muted);">Как рождались великие шедевры: от первой ноты до премьеры.</p>
        </div>

        {posts.length > 0 && (
            <div style="position: relative; margin-bottom: 40px; max-width: 100%;">
                <svg width="20" height="20" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #aaa; pointer-events: none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="pageSearch" class="page-search-input" placeholder="Поиск по статьям рубрики..." autocomplete="off">
            </div>
        )}

        {posts.length > 0 ? (
            <div class="articles-grid" id="articlesGrid">
                {posts.map((post) => (
                    <article class="article-card">
                        {post.mainImage && (
                            <a href={`/blog/${post.slug?.current}`}>
                                <div class="article-image">
                                    <img src={urlFor(post.mainImage).width(400).height(260).auto('format').url()} alt={post.title} loading="lazy" />
                                </div>
                            </a>
                        )}
                        <div class="article-body">
                            <h3 class="article-title"><a href={`/blog/${post.slug?.current}`}>{post.title}</a></h3>
                            <div class="article-footer" style="display: flex; justify-content: space-between;">
                                <span>{post.authorName || 'Редакция'}</span>
                                <span>{new Date(post.publishedAt).toLocaleDateString('ru-RU')}</span>
                            </div>
                        </div>
                    </article>
                ))}
                <div id="noResults" style="display: none; grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted); font-size: 1.2rem;">
                    По вашему запросу ничего не найдено 😔
                </div>
            </div>
        ) : (
            <div class="no-posts-container">
                <p class="no-posts">В этой рубрике пока нет статей.</p>
            </div>
        )}
    </main>
</MainLayout>

<style>
    .content { padding: 40px 60px; }
    .page-header { margin-bottom: 30px; }
    .page-title { font-family: var(--font-head); font-size: 2.5rem; margin-bottom: 15px; }
    .page-search-input { width: 100%; padding: 16px 16px 16px 48px; border: 1px solid rgba(0,0,0,0.1); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 1.05rem; color: var(--text-main); outline: none; transition: all 0.3s ease; }
    .page-search-input:focus { border-color: var(--accent-primary); }
    .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; }
    .article-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); transition: 0.3s; display: flex; flex-direction: column; }
    .article-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); }
    .article-image { height: 220px; overflow: hidden; }
    .article-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .article-card:hover .article-image img { transform: scale(1.05); }
    .article-body { padding: 30px; display: flex; flex-direction: column; flex-grow: 1; }
    .article-title { font-family: var(--font-head); font-size: 1.4rem; margin-bottom: 15px; line-height: 1.3; }
    .article-title a { color: var(--text-main); transition: color 0.2s; }
    .article-title a:hover { color: var(--accent-primary); }
    .article-footer { margin-top: auto; font-size: 0.85rem; color: var(--text-muted); padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); }
    .no-posts-container { background: #fff; padding: 40px; border-radius: var(--radius-lg); text-align: center; border: 1px dashed #ccc; }
    .no-posts { font-size: 1.2rem; color: var(--text-muted); font-weight: 500; }
</style>

<script is:inline>
    const searchInput = document.getElementById('pageSearch');
    const cards = document.querySelectorAll('.article-card');
    const noResultsMsg = document.getElementById('noResults');
    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            let visibleCount = 0;
            cards.forEach(card => {
                const title = card.querySelector('.article-title').textContent.toLowerCase();
                if (title.includes(query)) { card.style.display = 'flex'; visibleCount++; } 
                else { card.style.display = 'none'; }
            });
            if (noResultsMsg) noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
        });
    }
</script>