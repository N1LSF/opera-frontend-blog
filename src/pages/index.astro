---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

// Настройки главной (цитата)
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  quoteText,
  quoteAuthor
}`);

const allPosts = await sanityClient.fetch(`*[_type == "post" && !(_id in path("drafts.**"))] | order(publishedAt desc){
  title,
  slug,
  publishedAt,
  excerpt,
  "categoryName": category->title,
  "authorName": author->name,
  "composerName": composer->name,
  mainImage
}`);

const heroPost = allPosts[0];
---
<MainLayout title="Главная">
    <main class="content">

        <!-- ЖУРНАЛЬНЫЙ ДАШБОРД -->
        <div class="editorial-dashboard" id="dashboard">
            
            <div class="hero-column" id="heroColumn">
                {heroPost && (
                    <article class="hero-card">
                        <a href={`/blog/${heroPost.slug?.current || '#'}/`} class="hero-link">
                            <div class="hero-image-wrapper">
                                {heroPost.mainImage ? (
                                    <img src={urlFor(heroPost.mainImage).width(800).height(500).auto('format').url()} alt={heroPost.title} class="hero-img" />
                                ) : (
                                    <div class="hero-placeholder"></div>
                                )}
                                {heroPost.categoryName && (
                                    <span class="hero-badge">{heroPost.categoryName}</span>
                                )}
                            </div>
                            <div class="hero-content">
                                <h2 class="hero-title">{heroPost.title}</h2>
                                <p class="hero-excerpt">{heroPost.excerpt || 'Читайте подробный разбор и историю создания этого шедевра в нашей новой статье.'}</p>
                                <div class="hero-footer">
                                    <span class="read-more">Читать статью →</span>
                                </div>
                            </div>
                        </a>
                    </article>
                )}
            </div>

            <aside class="widgets-column">
                
                <div class="widget search-widget">
                    <svg width="18" height="18" class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="text" id="mainSearch" class="main-search-input" placeholder="Найти оперу, композитора, рубрику..." autocomplete="off">
                </div>

                <div class="widget quote-widget">
                    <svg class="quote-icon" width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                    <p class="quote-text">{settings?.quoteText || '«Опера — это когда парень получает удар кинжалом в спину, но вместо того, чтобы истекать кровью, он поет».'}</p>
                    <span class="quote-author">{settings?.quoteAuthor || '— Эдуард Элгар'}</span>
                </div>

                    <div class="widget tags-widget">
                        <h3>Популярное</h3>
                        <div class="tags-flex">
                            <a href="/opera-plots/" class="tag-chip">Сюжеты</a>
                            <a href="/history/" class="tag-chip">История создания</a>
                            <a href="/librettists/" class="tag-chip">Либреттисты</a>
                            <a href="/censourship/" class="tag-chip">Цензура</a>
                        </div>
                    </div>
                </div>

            </aside>
        </div>

        <div class="section-header" id="sectionTitle">
            <h2 class="section-title">Свежие материалы</h2>
        </div>

        <div class="articles-grid" id="mainGrid">
            {allPosts.map((post, index) => (
                <article 
                    class={`article-card ${index === 0 ? 'hero-duplicate' : ''}`}
                    data-title={post.title}
                    data-author={post.authorName || ''}
                    data-composer={post.composerName || ''}
                    data-category={post.categoryName || ''}
                >
                    {post.mainImage && (
                        <a href={`/blog/${post.slug?.current || '#'}/`}>
                            <div class="article-image">
                                <img src={urlFor(post.mainImage).width(400).height(260).auto('format').url()} alt={post.title} loading="lazy" />
                            </div>
                        </a>
                    )}
                    <div class="article-body">
                        {post.categoryName && <span class="card-category">{post.categoryName}</span>}
                        <h3 class="article-title"><a href={`/blog/${post.slug?.current || '#'}/`}>{post.title}</a></h3>
                        <div class="article-footer">
                            <span>{new Date(post.publishedAt).toLocaleDateString('ru-RU')}</span>
                        </div>
                    </div>
                </article>
            ))}
            
            <div id="noResults" style="display: none; grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted); font-size: 1.2rem;">
                По вашему запросу ничего не найдено 😔
            </div>
        </div>

    </main>
</MainLayout>

<style>
    .content { padding: 40px 60px; }

    /* === ДАШБОРД: FLEXBOX С ПЛАВНОЙ АНИМАЦИЕЙ === */
    .editorial-dashboard { 
        display: flex; 
        align-items: stretch; 
        gap: 30px; 
        margin-bottom: 60px; 
        transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
    }
    
    .hero-column { 
        flex: 2 1 0; 
        overflow: hidden; 
        opacity: 1; 
        transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
        max-height: 800px; 
        min-width: 0; 
    }
    
    .widgets-column { 
        flex: 1 1 0; 
        display: flex; 
        flex-direction: column; 
        gap: 20px; 
        transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
        min-width: 0; 
    }

    .collapsible-wrapper { 
        display: flex; 
        flex-direction: column; 
        gap: 20px; 
        overflow: hidden; 
        max-height: 800px; 
        opacity: 1; 
        transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1); 
    }

    /* === СОСТОЯНИЕ АКТИВНОГО ПОИСКА === */
    .editorial-dashboard.is-searching { 
        gap: 0; 
        margin-bottom: 40px; 
    }
    .editorial-dashboard.is-searching .hero-column { 
        flex: 0 0 0; 
        opacity: 0; 
        max-height: 0; 
    }
    .editorial-dashboard.is-searching .widgets-column { 
        flex: 1 1 100%; 
    }
    .editorial-dashboard.is-searching .collapsible-wrapper { 
        max-height: 0; 
        opacity: 0; 
        margin: 0; 
        gap: 0; 
    }
    .editorial-dashboard.is-searching .search-widget { 
        box-shadow: 0 10px 40px rgba(0,0,0,0.08); 
        border-color: var(--accent-primary); 
    }

    /* Герой-карточка */
    .hero-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: 0.3s; height: 100%; display: flex; flex-direction: column; }
    .hero-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .hero-image-wrapper { position: relative; height: 350px; overflow: hidden; }
    .hero-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
    .hero-card:hover .hero-img { transform: scale(1.05); }
    .hero-placeholder { width: 100%; height: 100%; background: #eee; }
    .hero-badge { position: absolute; top: 20px; left: 20px; background: rgba(255,255,255,0.9); color: var(--accent-primary); padding: 6px 14px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; backdrop-filter: blur(5px); }
    .hero-content { padding: 40px; display: flex; flex-direction: column; flex-grow: 1; min-width: 400px; }
    .hero-title { font-family: var(--font-head); font-size: 2.5rem; line-height: 1.1; margin-bottom: 15px; color: var(--text-main); transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .hero-card:hover .hero-title { color: var(--accent-primary); }
    .hero-excerpt { color: var(--text-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 25px; }
    .read-more { margin-top: auto; font-family: var(--font-head); font-weight: 700; color: var(--accent-primary); font-size: 1.1rem; }

    /* Виджеты */
    .widget { background: var(--bg-card); border-radius: var(--radius-lg); padding: 25px; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: all 0.3s ease; border: 1px solid transparent; }
    .search-widget { padding: 10px; position: relative; display: flex; align-items: center; }
    .search-icon { position: absolute; left: 24px; color: #aaa; }
    .main-search-input { width: 100%; padding: 18px 20px 18px 50px; border: none; background: transparent; font-family: var(--font-body); font-size: 1.05rem; outline: none; color: var(--text-main); }
    
    .quote-widget { background: var(--accent-primary); color: #fff; position: relative; overflow: hidden; padding: 35px 30px; }
    .quote-icon { position: absolute; top: -10px; right: -10px; width: 100px; height: 100px; opacity: 0.1; transform: rotate(15deg); }
    .quote-text { font-family: var(--font-head); font-size: 1.2rem; line-height: 1.5; font-style: italic; margin-bottom: 15px; position: relative; z-index: 2; }
    .quote-author { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }

    .tags-widget h3 { font-family: var(--font-head); font-size: 1.1rem; margin-bottom: 15px; color: var(--text-main); }
    .tags-flex { display: flex; flex-wrap: wrap; gap: 10px; }
    .tag-chip { background: var(--bg-body); color: var(--text-muted); padding: 8px 15px; border-radius: 50px; font-size: 0.85rem; font-weight: 500; transition: 0.2s; }
    .tag-chip:hover { background: var(--accent-light); color: var(--accent-primary); transform: translateY(-2px); }

    /* СЕТКА СВЕЖИХ МАТЕРИАЛОВ */
    .section-header { 
        margin-bottom: 30px; 
        border-bottom: 2px solid rgba(0,0,0,0.03); 
        padding-bottom: 15px; 
        overflow: hidden; 
        max-height: 100px; 
        opacity: 1; 
        transition: all 0.4s ease; 
    }
    .section-header.hidden { max-height: 0; opacity: 0; margin: 0; padding: 0; border: none; }
    .section-title { font-family: var(--font-head); font-size: 2rem; color: var(--text-main); }
    
    .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; }
    
    .hero-duplicate { display: none !important; }
    .grid-searching .hero-duplicate { display: flex !important; }

    .article-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: 0.3s; display: flex; flex-direction: column; }
    .article-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .article-image { height: 200px; overflow: hidden; }
    .article-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .article-card:hover .article-image img { transform: scale(1.05); }
    .article-body { padding: 25px; display: flex; flex-direction: column; flex-grow: 1; }
    .card-category { font-size: 0.75rem; color: var(--accent-primary); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 10px; }
    .article-title { font-family: var(--font-head); font-size: 1.3rem; margin-bottom: 15px; line-height: 1.3; }
    .article-title a { color: var(--text-main); transition: color 0.2s; }
    .article-title a:hover { color: var(--accent-primary); }
    .article-footer { margin-top: auto; font-size: 0.85rem; color: var(--text-muted); padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); }

    /* АДАПТИВ */
    @media (max-width: 1000px) {
        .content { padding: 30px 20px; }
        .editorial-dashboard { flex-direction: column; align-items: stretch; gap: 20px; }
        .hero-column { flex: none; width: 100%; order: 2; }
        .widgets-column { flex: none; width: 100%; order: 1; }
        .hero-image-wrapper { height: 250px; }
        .hero-content { min-width: 0; }
        .hero-title { white-space: normal; }
    }
    @media (max-width: 768px) {
        .content { padding: 20px 15px; }
        .hero-content { padding: 25px; }
        .hero-title { font-size: 1.8rem; }
        .hero-excerpt { font-size: 1rem; }
        .articles-grid { grid-template-columns: 1fr; gap: 20px; }
        .main-search-input { font-size: 16px; }
        .quote-widget { padding: 25px 20px; }
    }
</style>

<script>
    function initMainSearch() {
        const searchInput = document.getElementById('mainSearch') as HTMLInputElement;
        const dashboard = document.getElementById('dashboard');
        const heroColumn = document.getElementById('heroColumn');
        const mainGrid = document.getElementById('mainGrid');
        const sectionTitle = document.getElementById('sectionTitle');
        const noResultsMsg = document.getElementById('noResults');
        const quoteWidget = document.querySelector('.quote-widget') as HTMLElement;
        const tagsWidget = document.querySelector('.tags-widget') as HTMLElement;

        if (!searchInput || !dashboard || !mainGrid) return;

        // Снимаем старый обработчик: клонируем инпут
        const freshInput = searchInput.cloneNode(true) as HTMLInputElement;
        searchInput.parentNode!.replaceChild(freshInput, searchInput);

        freshInput.addEventListener('input', () => {
            const query = freshInput.value.trim().toLowerCase();
            const cards = mainGrid.querySelectorAll('.article-card');

            const isSearching = query.length > 0;

            // === UI: скрываем/показываем hero и виджеты ===
            if (isSearching) {
                dashboard.classList.add('is-searching');
                mainGrid.classList.add('grid-searching');
                if (sectionTitle) sectionTitle.classList.add('hidden');
                if (heroColumn) heroColumn.style.display = 'none';
                if (quoteWidget) quoteWidget.style.display = 'none';
                if (tagsWidget) tagsWidget.style.display = 'none';
            } else {
                dashboard.classList.remove('is-searching');
                mainGrid.classList.remove('grid-searching');
                if (sectionTitle) sectionTitle.classList.remove('hidden');
                if (heroColumn) heroColumn.style.display = '';
                if (quoteWidget) quoteWidget.style.display = '';
                if (tagsWidget) tagsWidget.style.display = '';
            }

            // === Фильтрация карточек ===
            if (!isSearching) {
                cards.forEach((card) => {
                    (card as HTMLElement).style.display = '';
                });
                if (noResultsMsg) noResultsMsg.style.display = 'none';
                return;
            }

            // Разбиваем запрос на слова — каждое должно матчиться
            const queryWords = query.split(/\s+/).filter(w => w.length > 0);

            let visibleCount = 0;
            cards.forEach((card) => {
                const el = card as HTMLElement;
                const haystack = [
                    el.dataset.title || '',
                    el.dataset.author || '',
                    el.dataset.composer || '',
                    el.dataset.category || ''
                ].join(' ').toLowerCase();

                const matches = queryWords.every(word => haystack.includes(word));

                if (matches) {
                    el.style.display = 'flex';
                    visibleCount++;
                } else {
                    el.style.display = 'none';
                }
            });

            if (noResultsMsg) {
                noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        });
    }

    initMainSearch();
    document.addEventListener('astro:after-swap', initMainSearch);
</script>