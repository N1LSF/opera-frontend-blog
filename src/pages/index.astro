---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

// Получаем все посты (отсортированные по дате)
const allPosts = await sanityClient.fetch(`*[_type == "post" && !(_id in path("drafts.**"))] | order(publishedAt desc){
  title,
  slug,
  publishedAt,
  excerpt,
  "categoryName": categories[0]->title,
  mainImage
}`);

// Главный пост (первый)
const heroPost = allPosts[0];
// Остальные посты для сетки
const gridPosts = allPosts.slice(1);
---

<MainLayout title="Главная">
    <main class="content">

        <!-- НОВЫЙ ЖУРНАЛЬНЫЙ ДАШБОРД (Верхняя часть) -->
        <div class="editorial-dashboard">
            
            <!-- Левая колонка: Главная статья -->
            <div class="hero-column">
                {heroPost && (
                    <article class="hero-card">
                        <a href={`/blog/${heroPost.slug?.current || '#'}/`} class="hero-link">
                            <div class="hero-image-wrapper">
                                {heroPost.mainImage ? (
                                    <img src={urlFor(heroPost.mainImage).width(800).height(500).auto('format').url()} alt={heroPost.title} class="hero-img" />
                                ) : (
                                    <div class="hero-placeholder"></div>
                                )}
                                {heroPost.categoryName && (
                                    <span class="hero-badge">{heroPost.categoryName}</span>
                                )}
                            </div>
                            <div class="hero-content">
                                <h2 class="hero-title">{heroPost.title}</h2>
                                <p class="hero-excerpt">{heroPost.excerpt || 'Читайте подробный разбор и историю создания этого шедевра в нашей новой статье.'}</p>
                                <div class="hero-footer">
                                    <span class="read-more">Читать статью →</span>
                                </div>
                            </div>
                        </a>
                    </article>
                )}
            </div>

            <!-- Правая колонка: Поиск и виджеты (Закрываем пустоту!) -->
            <aside class="widgets-column">
                
                <!-- 1. Поиск (теперь на своем месте) -->
                <div class="widget search-widget">
                    <svg width="18" height="18" class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="text" id="mainSearch" class="main-search-input" placeholder="Найти оперу, автора..." autocomplete="off">
                </div>

                <!-- 2. Элегантная цитата (Добавляет шарма и премиальности) -->
                <div class="widget quote-widget">
                    <svg class="quote-icon" width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                    <p class="quote-text">«Опера — это когда парень получает удар кинжалом в спину, но вместо того, чтобы истекать кровью, он поет».</p>
                    <span class="quote-author">— Эдуард Элгар</span>
                </div>

                <!-- 3. Быстрые рубрики (Визуально уплотняет колонку) -->
                <div class="widget tags-widget">
                    <h3>Популярное</h3>
                    <div class="tags-flex">
                        <a href="/opera-plots/" class="tag-chip">Сюжеты</a>
                        <a href="/history/" class="tag-chip">История создания</a>
                        <a href="/librettists/" class="tag-chip">Либреттисты</a>
                        <a href="/censourship/" class="tag-chip">Цензура</a>
                    </div>
                </div>

            </aside>
        </div>

        <!-- СЕКЦИЯ СВЕЖИХ МАТЕРИАЛОВ -->
        <div class="section-header">
            <h2 class="section-title">Свежие материалы</h2>
        </div>

        <div class="articles-grid" id="mainGrid">
            {gridPosts.map((post) => (
                <article class="article-card">
                    {post.mainImage && (
                        <a href={`/blog/${post.slug?.current || '#'}/`}>
                            <div class="article-image">
                                <img src={urlFor(post.mainImage).width(400).height(260).auto('format').url()} alt={post.title} loading="lazy" />
                            </div>
                        </a>
                    )}
                    <div class="article-body">
                        {post.categoryName && <span class="card-category">{post.categoryName}</span>}
                        <h3 class="article-title"><a href={`/blog/${post.slug?.current || '#'}/`}>{post.title}</a></h3>
                        <div class="article-footer">
                            <span>{new Date(post.publishedAt).toLocaleDateString('ru-RU')}</span>
                        </div>
                    </div>
                </article>
            ))}
        </div>

    </main>
</MainLayout>

<style>
    /* БАЗОВЫЕ СТИЛИ */
    .content { padding: 40px 60px; }

    /* === ЖУРНАЛЬНЫЙ ДАШБОРД (ГЛАВНАЯ ФИШКА) === */
    .editorial-dashboard {
        display: grid;
        grid-template-columns: 2fr 1fr; /* Левая часть широкая, правая - узкая */
        gap: 30px;
        margin-bottom: 60px;
        align-items: start;
    }

    /* Главный пост */
    .hero-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: 0.3s; height: 100%; display: flex; flex-direction: column; }
    .hero-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .hero-image-wrapper { position: relative; height: 350px; overflow: hidden; }
    .hero-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
    .hero-card:hover .hero-img { transform: scale(1.05); }
    .hero-placeholder { width: 100%; height: 100%; background: #eee; }
    .hero-badge { position: absolute; top: 20px; left: 20px; background: rgba(255,255,255,0.9); color: var(--accent-primary); padding: 6px 14px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; backdrop-filter: blur(5px); }
    .hero-content { padding: 40px; display: flex; flex-direction: column; flex-grow: 1; }
    .hero-title { font-family: var(--font-head); font-size: 2.5rem; line-height: 1.1; margin-bottom: 15px; color: var(--text-main); transition: color 0.2s; }
    .hero-card:hover .hero-title { color: var(--accent-primary); }
    .hero-excerpt { color: var(--text-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 25px; }
    .read-more { margin-top: auto; font-family: var(--font-head); font-weight: 700; color: var(--accent-primary); font-size: 1.1rem; }

    /* Правая колонка с виджетами */
    .widgets-column { display: flex; flex-direction: column; gap: 20px; }
    .widget { background: var(--bg-card); border-radius: var(--radius-lg); padding: 25px; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); }
    
    /* Поиск */
    .search-widget { padding: 10px; position: relative; display: flex; align-items: center; }
    .search-icon { position: absolute; left: 24px; color: #aaa; }
    .main-search-input { width: 100%; padding: 18px 20px 18px 50px; border: none; background: transparent; font-family: var(--font-body); font-size: 1.05rem; outline: none; }
    
    /* Виджет Цитаты (Выглядит "Дорого") */
    .quote-widget { background: var(--accent-primary); color: #fff; position: relative; overflow: hidden; padding: 35px 30px; }
    .quote-icon { position: absolute; top: -10px; right: -10px; width: 100px; height: 100px; opacity: 0.1; transform: rotate(15deg); }
    .quote-text { font-family: var(--font-head); font-size: 1.2rem; line-height: 1.5; font-style: italic; margin-bottom: 15px; position: relative; z-index: 2; }
    .quote-author { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; }

    /* Виджет Тегов */
    .tags-widget h3 { font-family: var(--font-head); font-size: 1.1rem; margin-bottom: 15px; color: var(--text-main); }
    .tags-flex { display: flex; flex-wrap: wrap; gap: 10px; }
    .tag-chip { background: var(--bg-body); color: var(--text-muted); padding: 8px 15px; border-radius: 50px; font-size: 0.85rem; font-weight: 500; transition: 0.2s; }
    .tag-chip:hover { background: var(--accent-light); color: var(--accent-primary); transform: translateY(-2px); }

    /* === СЕТКА СВЕЖИХ МАТЕРИАЛОВ === */
    .section-header { margin-bottom: 30px; border-bottom: 2px solid rgba(0,0,0,0.03); padding-bottom: 15px; }
    .section-title { font-family: var(--font-head); font-size: 2rem; color: var(--text-main); }
    
    .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; }
    .article-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.03)); transition: 0.3s; display: flex; flex-direction: column; }
    .article-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .article-image { height: 200px; overflow: hidden; }
    .article-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .article-card:hover .article-image img { transform: scale(1.05); }
    .article-body { padding: 25px; display: flex; flex-direction: column; flex-grow: 1; }
    .card-category { font-size: 0.75rem; color: var(--accent-primary); text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 10px; }
    .article-title { font-family: var(--font-head); font-size: 1.3rem; margin-bottom: 15px; line-height: 1.3; }
    .article-title a { color: var(--text-main); transition: color 0.2s; }
    .article-title a:hover { color: var(--accent-primary); }
    .article-footer { margin-top: auto; font-size: 0.85rem; color: var(--text-muted); padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); }

    /* === АДАПТИВ (ЧТОБЫ НА ТЕЛЕФОНЕ БЫЛО ИДЕАЛЬНО) === */
    @media (max-width: 1000px) {
        .content { padding: 30px 20px; }
        .editorial-dashboard { grid-template-columns: 1fr; /* Колонки выстраиваются друг под друга */ }
        .widgets-column { order: -1; /* Поиск и цитата поднимаются НАВЕРХ перед Главной статьей */ }
        .hero-image-wrapper { height: 250px; }
    }

    @media (max-width: 768px) {
        .content { padding: 20px 15px; }
        .hero-content { padding: 25px; }
        .hero-title { font-size: 1.8rem; }
        .hero-excerpt { font-size: 1rem; }
        .articles-grid { grid-template-columns: 1fr; gap: 20px; }
        .main-search-input { font-size: 16px; /* Фикс зума на iOS */ }
        .quote-widget { padding: 25px 20px; }
    }
</style>

<script>
    // Простейший скрипт поиска для Главной страницы
    function initMainSearch() {
        const searchInput = document.getElementById('mainSearch');
        const cards = document.querySelectorAll('.article-card');
        const heroCard = document.querySelector('.hero-column'); // Главный пост прячем при поиске
        const sectionTitle = document.querySelector('.section-header');

        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
                
                // Скрываем/Показываем Hero блок и заголовок
                if(query.length > 0) {
                    if(heroCard) (heroCard as HTMLElement).style.display = 'none';
                    if(sectionTitle) (sectionTitle as HTMLElement).style.display = 'none';
                } else {
                    if(heroCard) (heroCard as HTMLElement).style.display = 'block';
                    if(sectionTitle) (sectionTitle as HTMLElement).style.display = 'block';
                }

                // Фильтруем сетку
                cards.forEach(card => {
                    const title = card.querySelector('.article-title')?.textContent?.toLowerCase() || '';
                    if (title.includes(query)) {
                        (card as HTMLElement).style.display = 'flex';
                    } else {
                        (card as HTMLElement).style.display = 'none';
                    }
                });
            });
        }
    }

    initMainSearch();
    document.addEventListener('astro:after-swap', initMainSearch);
</script>