---
export const prerender = true;

import { sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

const terms = await sanityClient.fetch(`
  *[_type == "glossaryTerm"] | order(term asc) {
    term,
    definition,
    termType,
    "linkedPostSlug": linkedPost->slug.current
  }
`);

const grouped: Record<string, typeof terms> = {};

terms.forEach((t: any) => {
  const letter = t.term[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(t);
});

const letters = Object.keys(grouped).sort();

const typeConfig: Record<string, { label: string }> = {
  term:       { label: 'Термин' },
  librettist: { label: 'Либреттист' },
  opera:      { label: 'Опера' },
};
---

<MainLayout title="Глоссарий">
  <section class="glossary-page">

    <header class="glossary-header">
      <p class="glossary-overline">Справочник</p>
      <h1 class="glossary-title">Глоссарий</h1>
      <p class="glossary-desc">Термины, либреттисты и оперы — кратко и по существу</p>
    </header>

    <div class="glossary-controls">
      <div class="glossary-filters" role="tablist">
        <span class="filter-pill"></span>
        <button class="filter-btn active" data-filter="all" role="tab" aria-selected="true">Все</button>
        <button class="filter-btn" data-filter="term" role="tab" aria-selected="false">Термины</button>
        <button class="filter-btn" data-filter="librettist" role="tab" aria-selected="false">Либреттисты</button>
        <button class="filter-btn" data-filter="opera" role="tab" aria-selected="false">Оперы</button>
      </div>
    </div>

    <nav class="glossary-alphabet" aria-label="Алфавитная навигация">
      {letters.map(letter => (
        <a href={`#letter-${letter}`} class="alphabet-link">{letter}</a>
      ))}
    </nav>

    <div class="glossary-body">
      {letters.map(letter => (
        <section class="glossary-section" id={`letter-${letter}`}>
          <div class="section-letter-row">
            <span class="section-letter">{letter}</span>
            <span class="section-letter-line"></span>
          </div>
          <dl class="glossary-list">
            {grouped[letter].map((item: any) => (
              <div class="glossary-entry" data-type={item.termType}>
                <dt class="entry-term">
                  {item.linkedPostSlug ? (
                    <a href={`/posts/${item.linkedPostSlug}`} class="entry-link">
                      {item.term}
                      <svg class="entry-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="7" y1="17" x2="17" y2="7"></line>
                        <polyline points="7 7 17 7 17 17"></polyline>
                      </svg>
                    </a>
                  ) : (
                    <span>{item.term}</span>
                  )}
                  <span class="entry-badge">{typeConfig[item.termType]?.label || 'Термин'}</span>
                </dt>
                <dd class="entry-definition">{item.definition}</dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </div>

    <div class="glossary-empty" id="glossaryEmpty" style="display: none;">
      <p class="empty-text">В этой категории пока нет записей</p>
    </div>

  </section>
</MainLayout>

<style>
  .glossary-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px 96px;
  }

  /* HEADER */
  .glossary-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .glossary-overline {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--accent-primary);
    margin-bottom: 12px;
  }

  .glossary-title {
    font-family: var(--font-head);
    font-size: 3rem;
    font-weight: 400;
    color: var(--text-main);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .glossary-desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* FILTERS — sliding pill */
  .glossary-controls {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }

  .glossary-filters {
    display: flex;
    gap: 0;
    padding: 4px;
    background: var(--bg-card);
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
  }

  .filter-pill {
    position: absolute;
    top: 4px;
    left: 4px;
    height: calc(100% - 8px);
    border-radius: 8px;
    background: var(--accent-primary);
    box-shadow: 0 2px 8px rgba(128, 37, 37, 0.2);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 0;
    will-change: transform, width;
  }

  .filter-btn {
    padding: 8px 20px;
    border: none;
    border-radius: 8px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.25s ease;
    white-space: nowrap;
    position: relative;
    z-index: 1;
  }

  .filter-btn:hover {
    color: var(--text-main);
  }

  .filter-btn.active {
    color: #fff;
  }

  /* ALPHABET NAV */
  .glossary-alphabet {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .alphabet-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: all 0.2s ease;
  }

  .alphabet-link:hover {
    color: var(--accent-primary);
    background: rgba(128, 37, 37, 0.06);
  }

  /* SECTIONS */
  .glossary-section {
    margin-bottom: 48px;
  }

  .section-letter-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .section-letter {
    font-family: var(--font-head);
    font-size: 2rem;
    font-weight: 400;
    color: var(--accent-primary);
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }

  .section-letter-line {
    flex: 1;
    height: 1px;
    background: rgba(128, 37, 37, 0.12);
  }

  /* ENTRIES */
  .glossary-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .glossary-entry {
    padding: 20px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    transition: opacity 0.2s ease;
  }

  .glossary-entry:last-child {
    border-bottom: none;
  }

  .glossary-entry.hidden {
    display: none;
  }

  .entry-term {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
    font-family: var(--font-head);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text-main);
    letter-spacing: -0.02em;
  }

  .entry-link {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    color: var(--text-main);
    border-bottom: 1px solid rgba(128, 37, 37, 0.25);
    transition: all 0.2s ease;
  }

  .entry-link:hover {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }

  .entry-arrow {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    opacity: 0;
    transform: translateY(1px);
    transition: opacity 0.2s ease;
  }

  .entry-link:hover .entry-arrow {
    opacity: 0.6;
  }

  .entry-badge {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    opacity: 0.5;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-definition {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
    padding-left: 0;
  }

  /* EMPTY STATE */
  .glossary-empty {
    text-align: center;
    padding: 64px 0;
  }

  .empty-text {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-muted);
    opacity: 0.6;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .glossary-page {
      padding: 0 16px 80px;
    }

    .glossary-title {
      font-size: 2.2rem;
    }

    .glossary-filters {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .alphabet-link {
      width: 32px;
      height: 32px;
      font-size: 0.8rem;
    }

    .section-letter {
      font-size: 1.6rem;
    }

    .entry-term {
      flex-wrap: wrap;
      gap: 6px;
    }

    .entry-badge {
      order: 2;
    }
  }
</style>

<script>
  function initGlossaryFilters() {
    const container = document.querySelector('.glossary-filters');
    const buttons = document.querySelectorAll('.filter-btn');
    const pill = document.querySelector('.filter-pill') as HTMLElement;
    const entries = document.querySelectorAll('.glossary-entry');
    const sections = document.querySelectorAll('.glossary-section');
    const emptyState = document.getElementById('glossaryEmpty');

    if (!container || !pill || buttons.length === 0) return;

    function movePill(btn: HTMLElement) {
      const containerRect = container!.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      const offsetLeft = btnRect.left - containerRect.left - 4;
      const width = btnRect.width;

      pill.style.width = `${width}px`;
      pill.style.transform = `translateX(${offsetLeft}px)`;
    }

    // Инициализация без анимации
    const activeBtn = container.querySelector('.filter-btn.active') as HTMLElement;
    if (activeBtn) {
      pill.style.transition = 'none';
      movePill(activeBtn);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          pill.style.transition = '';
        });
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        movePill(btn as HTMLElement);

        const filter = btn.getAttribute('data-filter');

        let visibleCount = 0;
        entries.forEach(entry => {
          const el = entry as HTMLElement;
          if (filter === 'all' || el.dataset.type === filter) {
            el.classList.remove('hidden');
            visibleCount++;
          } else {
            el.classList.add('hidden');
          }
        });

        sections.forEach(section => {
          const visible = section.querySelectorAll('.glossary-entry:not(.hidden)');
          (section as HTMLElement).style.display = visible.length ? '' : 'none';
        });

        if (emptyState) {
          emptyState.style.display = visibleCount === 0 ? '' : 'none';
        }
      });
    });
  }

  function initAlphabetScroll() {
    const links = document.querySelectorAll('.alphabet-link');
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  initGlossaryFilters();
  initAlphabetScroll();
  document.addEventListener('astro:after-swap', () => {
    initGlossaryFilters();
    initAlphabetScroll();
  });
</script>