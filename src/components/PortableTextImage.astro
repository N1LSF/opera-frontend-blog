---
import { urlFor } from '../lib/sanity';

const { node } = Astro.props;
---

<figure class="rich-text-image">
    <img src={urlFor(node).width(800).auto('format').url()} alt={node.alt || 'Изображение статьи'} />
    {node.caption && <figcaption>{node.caption}</figcaption>}
</figure>

<style>
    .rich-text-image {
        margin: 2.5em 0;
        text-align: center;
    }
    .rich-text-image img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: block;
        margin: 0 auto;
    }
    figcaption {
        margin-top: 10px;
        font-size: 0.9rem;
        color: #666;
        font-style: italic;
    }
</style>