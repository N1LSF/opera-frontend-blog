---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';
import { PortableText } from 'astro-portabletext';

const about = await sanityClient.fetch(`*[_type == "aboutPage"][0]{
  pageTitle,
  photo,
  body
}`);
---

<MainLayout title="О блоге">
    <main class="content">
        <h1 class="page-title">{about?.pageTitle || 'О проекте'}</h1>

        <!-- БЛОК 1: ФОТО -->
        <div class="about-photo-card">
            {about?.photo ? (
                <img src={urlFor(about.photo).width(1200).auto('format').url()} alt="Фото автора" class="about-photo" />
            ) : (
                <div class="image-placeholder"></div>
            )}
        </div>

        <!-- БЛОК 2: ТЕКСТ -->
        <div class="about-text-card">
            {about?.body && about.body.length > 0 ? (
                <PortableText value={about.body} />
            ) : (
                <p>Текст скоро появится...</p>
            )}
        </div>
    </main>
</MainLayout>

<style>
    .content { 
        padding: 40px 60px; 
        max-width: 860px; 
        margin: 0 auto; 
    }

    .page-title { 
        font-family: var(--font-head); 
        font-size: 2.8rem; 
        margin-bottom: 40px; 
        text-align: center; 
    }

    /* БЛОК 1: ФОТО */
    .about-photo-card { 
        border-radius: var(--radius-lg); 
        overflow: hidden; 
        box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.05)); 
        margin-bottom: 30px; 
        background: #ffffff;
        max-height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .about-photo { 
        max-width: 100%; 
        max-height: 400px; 
        object-fit: contain;
        display: block;
    }
    .image-placeholder { 
        width: 100%; 
        height: 300px; 
        background: linear-gradient(45deg, var(--accent-light), #ffffff); 
        display: flex; 
        align-items: center; 
        justify-content: center; 
    }
    .image-placeholder::after { 
        content: 'Фото автора'; 
        color: var(--accent-primary); 
        font-family: var(--font-head); 
        font-size: 1.2rem; 
        opacity: 0.4; 
    }

    /* БЛОК 2: ТЕКСТ */
    .about-text-card { 
        background: var(--bg-card); 
        border-radius: var(--radius-lg); 
        padding: 50px; 
        box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.05)); 
        font-family: var(--font-body);
        font-size: 1.1rem; 
        line-height: 1.85; 
        color: var(--text-main); 
    }

    .about-text-card :global(p) { 
        margin-bottom: 1.5em; 
    }

    .about-text-card :global(strong) { 
        font-weight: 600; 
        color: #111; 
    }

    .about-text-card :global(em) { 
        font-family: var(--font-head); 
        font-style: italic; 
        color: #444; 
    }

    .about-text-card :global(ul) { 
        margin-bottom: 1.5em; 
        padding-left: 1.5em; 
    }

    .about-text-card :global(li) { 
        margin-bottom: 0.6em; 
        list-style-type: disc; 
    }

    .about-text-card :global(h2) { 
        font-family: var(--font-head); 
        font-size: 1.8rem; 
        font-weight: 400; 
        margin: 2em 0 0.8em; 
        color: var(--text-main); 
    }

    .about-text-card :global(blockquote) { 
        margin: 2em 0; 
        padding: 0 0 0 1.5em; 
        border-left: 3px solid var(--accent-primary); 
        font-style: italic; 
        font-family: var(--font-head); 
        font-size: 1.3rem; 
        color: #555; 
    }

    /* АДАПТИВ */
    @media (max-width: 1000px) {
        .content { padding: 30px 20px; }
        .about-text-card { padding: 35px; }
    }

    @media (max-width: 768px) {
        .content { padding: 20px 15px; }
        .page-title { font-size: 2rem; margin-bottom: 25px; }
        .about-text-card { padding: 25px; font-size: 1rem; }
    }
</style>