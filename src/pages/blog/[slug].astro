---
export const prerender = true;

import { sanityClient, urlFor } from '../../lib/sanity';
import MainLayout from '../../layouts/MainLayout.astro';
import { PortableText } from 'astro-portabletext';
import PortableTextImage from '../../components/PortableTextImage.astro';

const customComponents = {
  type: {
    image: PortableTextImage,
  }
};

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current) && !(_id in path("drafts.**"))]{ slug }`);
  // ВОЗВРАЩАЕМ ПУТИ
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`*[_type == "post" && slug.current == $slug][0]{
  title,
  publishedAt,
  mainImage,
  body,
  "authorName": author->name,
  "authorImage": author->image,
  "categoryTitles": categories[]->title
}`, { slug });

if (!post) {
  return Astro.redirect('/404');
}
---

<MainLayout title={post.title}>
    <article class="article-container">
        
        <header class="article-header">
            {post.categoryTitles && post.categoryTitles.length > 0 && (
                <div class="category-tag">{post.categoryTitles[0]}</div>
            )}
            <h1 class="article-main-title">{post.title}</h1>
            
            <div class="article-meta">
                <div class="meta-author">
                    {post.authorImage ? (
                        <!-- ОПТИМИЗАЦИЯ АВАТАРКИ -->
                        <img src={urlFor(post.authorImage).width(96).height(96).auto('format').url()} alt={post.authorName} class="author-avatar" />
                    ) : (
                        <div class="author-avatar-placeholder">👤</div>
                    )}
                    <span>{post.authorName || 'Редакция'}</span>
                </div>
                <span class="meta-dot">•</span>
                <time class="meta-date">
                    {new Date(post.publishedAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
            </div>
        </header>

        {post.mainImage && (
            <div class="article-hero-image">
                <!-- ОПТИМИЗАЦИЯ БОЛЬШОЙ КАРТИНКИ: Ширина 1200px (ретина), формат авто -->
                <img 
                    src={urlFor(post.mainImage).width(1200).auto('format').url()} 
                    alt={post.title}
                    loading="eager" 
                />
            </div>
        )}

        <div class="editorial-content">
            {post.body ? (
                <PortableText value={post.body} components={customComponents} />
            ) : (
                <p>Текст статьи скоро появится...</p>
            )}
        </div>
        
    </article>
</MainLayout>

<style>
/* Твои стили без изменений */
    .article-container { 
        width: 100%; 
        max-width: 760px; 
        margin: 0 auto; 
        padding: 0 20px 100px; 
    }
    
    .article-header { 
        margin-bottom: 50px; 
        text-align: center; 
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .category-tag { 
        display: inline-block; 
        color: var(--accent-primary); 
        font-size: 0.85rem; 
        font-weight: 600; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
        margin-bottom: 20px; 
    }
    
    .article-main-title { 
        font-family: var(--font-head); 
        font-size: 3.5rem; 
        line-height: 1.15; 
        margin-bottom: 35px; 
        color: var(--text-main); 
        font-weight: 400;
    }
    
    .article-meta { 
        display: flex; 
        align-items: center; 
        gap: 15px; 
        font-family: var(--font-body);
        font-size: 1rem; 
        color: var(--text-muted); 
    }
    
    .meta-author { 
        display: flex; 
        align-items: center; 
        gap: 12px; 
        font-weight: 500; 
        color: var(--text-main); 
    }
    
    .author-avatar { 
        width: 40px; 
        height: 40px; 
        border-radius: 50%; 
        object-fit: cover; 
    }
    
    .author-avatar-placeholder { 
        width: 40px; 
        height: 40px; 
        border-radius: 50%; 
        background: #e0e0e0; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 1.2rem; 
    }

    .meta-dot {
        font-size: 1.2rem;
        line-height: 0;
    }
    
    .article-hero-image { 
        width: 100%; 
        margin-bottom: 60px; 
        border-radius: 24px;
        overflow: hidden; 
        box-shadow: 0 10px 40px rgba(0,0,0,0.04); 
    }
    
    .article-hero-image img { 
        width: 100%; 
        height: auto; 
        display: block; 
    }

    @media (max-width: 768px) {
        .article-main-title { font-size: 2.5rem; }
        .article-meta { flex-direction: column; gap: 8px; }
        .meta-dot { display: none; }
        .article-hero-image { border-radius: 16px; margin-bottom: 40px; }
    }
</style>

<style is:global>
.editorial-content {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.8;
    color: #333333;
    position: relative;
}

.editorial-content::before {
    content: '';
    position: fixed;
    top: 50%;
    left: calc(50% + 130px);
    transform: translate(-50%, -50%) rotate(-20deg);
    width: 350px;
    height: 350px;
    background: url('/favicon.svg') center / contain no-repeat;
    opacity: 0.035;
    pointer-events: none;
    user-select: none;
    z-index: 0;
}

    .editorial-content p { margin-bottom: 1.8em; }
    .editorial-content h2 { font-family: var(--font-head); font-size: 2.2rem; font-weight: 400; margin: 2em 0 1em; color: var(--text-main); line-height: 1.3; }
    .editorial-content h3 { font-family: var(--font-head); font-size: 1.6rem; font-weight: 400; margin: 1.8em 0 0.8em; color: var(--text-main); }
    .editorial-content strong { font-weight: 600; color: #111; }
    .editorial-content em { font-family: var(--font-head); font-style: italic; color: #444; }
    .editorial-content ul { margin-bottom: 2em; padding-left: 1.5em; list-style-type: none; }
    .editorial-content li { margin-bottom: 0.8em; position: relative; }
    .editorial-content ul li::before { content: "•"; color: var(--accent-primary); font-weight: bold; position: absolute; left: -1em; }
    .editorial-content blockquote { margin: 3em 0; padding: 0 0 0 1.5em; border-left: 3px solid var(--accent-primary); font-style: italic; font-family: var(--font-head); font-size: 1.4rem; color: #555; line-height: 1.6; }
    
    .editorial-content a { color: var(--accent-primary); text-decoration: none; border-bottom: 1px solid rgba(128, 37, 37, 0.3); transition: 0.2s; }
    .editorial-content a:hover { border-bottom-color: var(--accent-primary); background-color: rgba(128, 37, 37, 0.05); }

    .editorial-content img { border-radius: 16px; margin: 2.5em 0; width: 100%; height: auto; box-shadow: 0 4px 20px rgba(0,0,0,0.03); }

    /* БУКВИЦА — ВЕЗДЕ */
.editorial-content p:first-of-type::first-letter {
    font-family: var(--font-head);
    font-size: 3.5em;
    float: left;
    line-height: 0.8;
    margin-right: 8px;
    margin-top: 5px;
    color: var(--accent-primary) !important;
    font-weight: 400;
}

    @media (max-width: 768px) {
        .editorial-content::before {
            left: 50%;
            width: 250px;
            height: 250px;
        }
    }
</style>