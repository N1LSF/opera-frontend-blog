---
export const prerender = true;

import { sanityClient } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

const terms = await sanityClient.fetch(`
  *[_type == "glossaryTerm"] | order(term asc) {
    term,
    definition,
    termType,
    "linkedPostSlug": linkedPost->slug.current
  }
`);

// Группируем по первой букве
const grouped: Record<string, typeof terms> = {};

terms.forEach((t: any) => {
  const letter = t.term[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(t);
});

const letters = Object.keys(grouped).sort();

// Иконки по типу
const typeLabels: Record<string, string> = {
  term: '📖',
  librettist: '✍️',
  opera: '🎭',
};
---

<MainLayout title="Глоссарий">
  <div class="glossary-page">

    <header class="glossary-header">
      <h1 class="glossary-title">Глоссарий</h1>
      <p class="glossary-subtitle">Термины, либреттисты и оперы — всё в одном месте</p>
    </header>

    <!-- Алфавитная навигация -->
    <nav class="glossary-nav">
      {letters.map(letter => (
        <a href={`#letter-${letter}`} class="glossary-nav-letter">{letter}</a>
      ))}
    </nav>

    <!-- Фильтр по типу -->
    <div class="glossary-filters">
      <button class="filter-btn active" data-filter="all">Все</button>
      <button class="filter-btn" data-filter="term">📖 Термины</button>
      <button class="filter-btn" data-filter="librettist">✍️ Либреттисты</button>
      <button class="filter-btn" data-filter="opera">🎭 Оперы</button>
    </div>

    <!-- Список терминов -->
    <div class="glossary-content">
      {letters.map(letter => (
        <section class="glossary-section" id={`letter-${letter}`}>
          <div class="glossary-letter-heading">{letter}</div>
          <div class="glossary-cards">
            {grouped[letter].map((item: any) => (
              <div class={`glossary-card`} data-type={item.termType}>
                <div class="glossary-card-header">
                  <span class="glossary-card-icon">{typeLabels[item.termType] || '📖'}</span>
                  {item.linkedPostSlug ? (
                    <a href={`/posts/${item.linkedPostSlug}`} class="glossary-card-title glossary-card-link">
                      {item.term}
                    </a>
                  ) : (
                    <h3 class="glossary-card-title">{item.term}</h3>
                  )}
                </div>
                <p class="glossary-card-definition">{item.definition}</p>
                {item.linkedPostSlug && (
                  <a href={`/posts/${item.linkedPostSlug}`} class="glossary-card-readmore">
                    Читать подробнее →
                  </a>
                )}
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

  </div>
</MainLayout>

<style>
  .glossary-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px 100px;
  }

  .glossary-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .glossary-title {
    font-family: var(--font-head);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--text-main);
    margin-bottom: 12px;
  }

  .glossary-subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Алфавитная навигация */
  .glossary-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-bottom: 30px;
  }

  .glossary-nav-letter {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    font-family: var(--font-head);
    font-size: 1rem;
    color: var(--text-main);
    background: rgba(128, 37, 37, 0.05);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .glossary-nav-letter:hover {
    background: var(--accent-primary);
    color: #fff;
  }

  /* Фильтры */
  .glossary-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 50px;
  }

  .filter-btn {
    padding: 8px 20px;
    border: 1.5px solid rgba(128, 37, 37, 0.2);
    border-radius: 100px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-main);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: #fff;
  }

  /* Секции по буквам */
  .glossary-section {
    margin-bottom: 50px;
  }

  .glossary-letter-heading {
    font-family: var(--font-head);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--accent-primary);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid rgba(128, 37, 37, 0.1);
  }

  /* Карточки */
  .glossary-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .glossary-card {
    padding: 24px 28px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    transition: all 0.25s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
  }

  .glossary-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .glossary-card.hidden {
    display: none;
  }

  .glossary-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .glossary-card-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .glossary-card-title {
    font-family: var(--font-head);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text-main);
    margin: 0;
  }

  .glossary-card-link {
    text-decoration: none;
    color: var(--text-main);
    border-bottom: 1px solid rgba(128, 37, 37, 0.3);
    transition: 0.2s;
  }

  .glossary-card-link:hover {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }

  .glossary-card-definition {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  .glossary-card-readmore {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 500;
    transition: 0.2s;
  }

  .glossary-card-readmore:hover {
    opacity: 0.7;
  }

  /* Мобилка */
  @media (max-width: 768px) {
    .glossary-title { font-size: 2.5rem; }
    .glossary-nav-letter { width: 32px; height: 32px; font-size: 0.85rem; }
    .glossary-card { padding: 18px 20px; }
    .glossary-letter-heading { font-size: 2rem; }
  }
</style>

<script>
  function initGlossaryFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.glossary-card');
    const sections = document.querySelectorAll('.glossary-section');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');

        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-type') === filter) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        // Скрываем пустые секции
        sections.forEach(section => {
          const visible = section.querySelectorAll('.glossary-card:not(.hidden)');
          (section as HTMLElement).style.display = visible.length ? '' : 'none';
        });
      });
    });
  }

  initGlossaryFilters();
  document.addEventListener('astro:after-swap', initGlossaryFilters);
</script>