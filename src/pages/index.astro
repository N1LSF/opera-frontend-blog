<script is:inline define:vars={{ searchItems }}>
    // Мы будем использовать объект window для хранения глобальных функций и переменных,
    // чтобы избежать конфликтов при повторном выполнении скрипта через ViewTransitions.

    // Функция для инициализации логики поиска
    function initializeSearch() {
        const input = document.getElementById('searchInput');
        const resultsBox = document.getElementById('searchResults');

        // Если элементов нет (например, на страницах, где нет поиска), просто выходим
        if (!input || !resultsBox) {
            // Если есть старые слушатели, которые мы добавляли, их нужно удалить,
            // чтобы не было утечек памяти или дублирования.
            // Для простоты, если поиска нет, мы просто убедимся, что старые слушатели не активны.
            // Если раньше был поиск, а теперь нет, его слушатели просто не найдут элементы.
            return; 
        }

        // ---------- УДАЛЯЕМ ЛОГИКУ КЛОНИРОВАНИЯ И ЗАМЕНЫ ЭЛЕМЕНТА! ----------
        // ViewTransitions уже позаботится об этом. Нам нужно только переинициализировать слушатели.

        // Удаляем старые слушатели событий, чтобы не было дублирования
        // Важно: чтобы удалить слушатель, нужно передать ту же самую функцию, что и добавляли.
        // Поэтому мы будем использовать именованную функцию или сохранять ссылки на них.
        // Простейший способ: если есть старый слушатель, удаляем его.
        // Для этого нам нужно хранить ссылку на предыдущую функцию-обработчик.
        
        // --- Переменная для хранения ссылки на обработчик input ---
        // (Она должна быть доступна глобально или в замыкании, чтобы мы могли ее удалить)
        if (window.currentSearchInputHandler) {
            input.removeEventListener('input', window.currentSearchInputHandler);
        }

        // --- Новый обработчик input ---
        const newSearchInputHandler = (e) => {
            const query = e.target.value.toLowerCase().trim();
            if (!query) { 
                resultsBox.style.display = 'none'; 
                return; 
            }

            const filteredPosts = searchItems.filter(item => {
                const titleStr = item.title.toLowerCase();
                const authorStr = item.author.toLowerCase();
                const catStr = item.categories.toLowerCase();

                if (query.length <= 2) {
                    const checkWords = (str) => str.split(/[\s\-«»",.]+/).some(word => word.startsWith(query));
                    return checkWords(titleStr) || checkWords(authorStr) || checkWords(catStr);
                } else {
                    return titleStr.includes(query) || authorStr.includes(query) || catStr.includes(query);
                }
            });

            if (filteredPosts.length > 0) {
                resultsBox.innerHTML = filteredPosts.map(item => 
                    `<li style="margin: 0; padding: 0;">
                        <a href="/blog/${item.slug}" style="display: flex; align-items: center; justify-content: space-between; gap: 15px; padding: 12px 24px; color: #2C2C2C; text-decoration: none; border-left: 3px solid transparent; transition: background 0.2s;" onmouseover="this.style.background='#fdf8f8'" onmouseout="this.style.background='transparent'">
                            <span style="font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${item.title}</span>
                            ${item.author ? `<span style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: #555; background: #F0F0F0; padding: 4px 12px 4px 6px; border-radius: 50px; white-space: nowrap; flex-shrink: 0;">
                                ${item.authorAvatar ? `<img src="${item.authorAvatar}" alt="" style="width: 22px; height: 22px; border-radius: 50%; object-fit: cover; display: block;">` : `👤`}
                                ${item.author}
                            </span>` : ''}
                        </a>
                    </li>`
                ).join('');
            } else {
                resultsBox.innerHTML = '<li style="padding: 15px 24px; color: #999; font-style: italic;">Ничего не найдено 😔</li>';
            }
            resultsBox.style.display = 'block';
        };

        input.addEventListener('input', newSearchInputHandler);
        window.currentSearchInputHandler = newSearchInputHandler; // Сохраняем ссылку для следующего удаления

        // Вешаем закрытие по клику вне поиска (один раз)
        // Этот слушатель можно оставить, как есть, если он не конфликтует.
        // Либо перенести внутрь initializeSearch и удалять/добавлять его.
        // Твоя текущая логика с `window.searchClickListenerAdded` уже неплоха.
        if (!window.searchClickListenerAdded) {
            document.addEventListener('click', (e) => {
                const box = document.getElementById('searchResults');
                if (box && !e.target.closest('.search-wrapper')) { box.style.display = 'none'; }
            });
            window.searchClickListenerAdded = true;
        }
    }

    // Вызываем инициализацию при первой загрузке и при каждом переходе ViewTransitions
    document.addEventListener('astro:page-load', initializeSearch);

    // Дополнительно: при первой загрузке страницы, чтобы не ждать astro:page-load,
    // если это первая страница.
    document.addEventListener('DOMContentLoaded', () => {
        // Проверяем, что initializeSearch не вызвана ViewTransitions,
        // чтобы избежать двойного вызова на первой загрузке.
        // Но `astro:page-load` уже довольно рано срабатывает.
        // Можно просто вызвать:
        // initializeSearch();
    });

</script>