---
import { ViewTransitions } from 'astro:transitions';
import { sanityClient } from '../lib/sanity';

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  footerText,
  footerLinks,
  contactEmail,
  contactText,
  socialLinks,
  cookieText
}`);
---

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Опера глазами читателя</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <ViewTransitions />
    
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ЧитаяОперу" />
    <link rel="manifest" href="/site.webmanifest" />

    <style is:global>
    /* КНОПКА НАВЕРХ */
    .scroll-top {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 900;
        width: 48px;
        height: 48px;
        border: none;
        border-radius: 50%;
        background: var(--accent-primary);
        color: #FFFFFF;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(128, 37, 37, 0.3);
        opacity: 0;
        visibility: hidden;
        transform: translateY(16px) scale(0.8);
        transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                    visibility 0.4s,
                    transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                    background 0.2s;
        -webkit-tap-highlight-color: transparent;
    }

    .scroll-top.visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }

    .scroll-top:hover {
        background: #601818;
        box-shadow: 0 6px 28px rgba(128, 37, 37, 0.45);
        transform: translateY(-2px) scale(1);
    }

    .scroll-top:active {
        transform: translateY(0) scale(0.95);
    }

    .scroll-top svg {
        transition: transform 0.2s;
    }

    .scroll-top:hover svg {
        transform: translateY(-2px);
    }

    @media (max-width: 600px) {
        .scroll-top {
            width: 44px;
            height: 44px;
            bottom: 24px;
            right: 20px;
        }
    }
        ::view-transition-old(root), ::view-transition-new(root) { animation: none !important; opacity: 1 !important; }

        :root {
            --bg-body: #F7F7F9; --bg-card: #FFFFFF; 
            --text-main: #1D1D1F; --text-muted: #6E6E73;
            --accent-primary: #802525; --accent-light: #FDF2F2; 
            --radius-lg: 24px; --radius-sm: 12px;
            --shadow-soft: 0 4px 20px rgba(0,0,0,0.03); 
            --font-head: 'Merriweather', serif; 
            --font-body: 'Inter', sans-serif;
            --font-button: 'Merriweather', serif;
        }
        
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ul, ol, li { list-style: none !important; } 
        html, body { overflow-x: hidden; width: 100%; }
        body { background-color: var(--bg-body); color: var(--text-main); font-family: var(--font-body); line-height: 1.6; min-height: 100vh; }
        a { text-decoration: none; color: inherit; transition: 0.3s; }

        .app-container { 
            display: grid; 
            grid-template-columns: 280px 1fr;
            max-width: 1440px; 
            margin: 0 auto; 
            min-height: 100vh;
            gap: 40px;
        }

        .sidebar { 
            position: sticky; top: 24px; height: calc(100vh - 48px); 
            display: flex; flex-direction: column; gap: 16px;
            z-index: 100; padding-left: 20px;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .mobile-header {
            display: none;
            position: sticky; top: 0; z-index: 990;
            background: var(--bg-card);
            padding: 15px 20px;
            box-shadow: var(--shadow-soft);
            align-items: center; justify-content: space-between;
        }
        .mobile-logo { font-family: var(--font-head); font-weight: 700; color: var(--accent-primary); font-size: 1.2rem; text-transform: uppercase; }
        .hamburger { background: none; border: none; color: var(--accent-primary); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 5px; }
        
        .sidebar-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0,0,0,0.5); z-index: 998; opacity: 0; transition: opacity 0.3s;
        }

        .sidebar-brand-card { background: var(--bg-card); padding: 30px 20px; border-radius: var(--radius-lg); box-shadow: var(--shadow-soft); text-align: center; }
        .logo { font-family: var(--font-head); font-weight: 700; font-size: 1.4rem; color: var(--accent-primary); line-height: 1.25; margin-bottom: 8px; display: block; text-transform: uppercase; }
        .slogan { font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; }
        .sidebar-nav-card { background: var(--bg-card); padding: 25px 15px; border-radius: var(--radius-lg); box-shadow: var(--shadow-soft); flex-grow: 1; overflow-y: auto; }
        .nav-group-title { font-size: 0.7rem; text-transform: uppercase; color: #A1A1A6; margin: 0 0 10px 15px; letter-spacing: 1.5px; font-weight: 700; }
        .nav-link { display: flex; align-items: center; padding: 10px 16px; border-radius: 12px; font-weight: 500; font-size: 0.95rem; color: var(--text-main); margin-bottom: 4px; transition: all 0.2s ease; }
        .nav-link:hover { background-color: rgba(0,0,0,0.03); transform: translateX(4px); }
        .nav-link.active { background-color: var(--accent-light); color: var(--accent-primary); }

        main { background: transparent; padding-top: 24px; min-width: 0; }

        /* ПОДВАЛ */
        .site-footer {
            padding: 0 8px 8px;
            max-width: 1440px;
            margin: 0 auto;
        }

        .footer-inner {
            background: var(--accent-primary);
            border-radius: var(--radius-lg);
            padding: 32px 40px 24px;
        }

        .footer-main {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 32px;
        }

        .footer-brand {
            flex-shrink: 0;
        }

        .footer-logo {
            font-family: var(--font-head);
            font-size: 1rem;
            font-weight: 700;
            color: #FFFFFF;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            line-height: 1.3;
        }

        .footer-slogan {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.45);
            margin-top: 4px;
            line-height: 1.4;
        }

        .footer-contacts {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

        .footer-email {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.8);
            transition: color 0.2s;
        }
        .footer-email svg {
            opacity: 0.6;
            flex-shrink: 0;
        }
        .footer-email:hover {
            color: #FFFFFF;
        }
        .footer-email:hover svg {
            opacity: 1;
        }

        .footer-socials {
            display: flex;
            gap: 8px;
        }

        .footer-social-link {
            padding: 6px 16px;
            border-radius: 8px;
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.7);
            font-size: 0.8rem;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }
        .footer-social-link:hover {
            background: rgba(255,255,255,0.16);
            color: #FFFFFF;
        }

        .footer-nav {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
            flex-shrink: 0;
        }

        .footer-nav-link {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.55);
            font-weight: 500;
            position: relative;
            transition: color 0.2s;
        }
        .footer-nav-link::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 0;
            height: 1px;
            background: #FFFFFF;
            transition: width 0.3s;
        }
        .footer-nav-link:hover {
            color: rgba(255,255,255,0.9);
        }
        .footer-nav-link:hover::after {
            width: 100%;
        }

        .footer-divider {
            height: 1px;
            background: rgba(255,255,255,0.1);
            margin: 24px 0 16px;
            border-radius: 1px;
        }

        .footer-bottom {
            text-align: center;
        }

        .footer-copy {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.3);
            letter-spacing: 0.3px;
        }

        @media (max-width: 768px) {
            .footer-inner {
                padding: 24px 20px 20px;
            }

            .footer-main {
                flex-direction: column;
                align-items: center;
                text-align: center;
                gap: 24px;
            }

            .footer-brand {
                text-align: center;
            }

            .footer-nav {
                align-items: center;
                flex-direction: row;
                flex-wrap: wrap;
                justify-content: center;
                gap: 16px;
            }

            .footer-logo {
                font-size: 0.9rem;
            }
        }

        /* КУКИ-БАННЕР */
        .cookie-banner {
            position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
            background: var(--bg-card); border-radius: var(--radius-sm);
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
            padding: 16px 24px; display: flex; align-items: center; gap: 16px;
            z-index: 9999; max-width: 560px; width: calc(100% - 40px);
            font-size: 0.85rem; color: var(--text-muted);
            opacity: 0; visibility: hidden;
            transition: opacity 0.4s, visibility 0.4s;
        }
        .cookie-banner.visible { opacity: 1; visibility: visible; }
        .cookie-banner p { flex: 1; margin: 0; line-height: 1.4; }
        .cookie-btn {
            background: var(--accent-primary); color: #fff; border: none;
            padding: 8px 20px; border-radius: 8px; cursor: pointer;
            font-family: var(--font-body); font-size: 0.85rem; font-weight: 500;
            white-space: nowrap; transition: background 0.2s;
        }
        .cookie-btn:hover { background: #601818; }

        /* ШТОРКА */
        .page-curtain { 
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
            background-color: var(--accent-primary); z-index: 999999; 
            display: flex; align-items: center; justify-content: center; 
            transform: translateY(100%); pointer-events: none; will-change: transform; 
            visibility: hidden; 
        }
        .page-curtain.visible { visibility: visible; }
        .curtain-text { font-family: var(--font-head); font-size: 3rem; font-weight: 700; color: #FFFFFF; text-align: center; opacity: 0; transition: opacity 0.3s ease; text-transform: uppercase; }
        .page-curtain.visible .curtain-text { opacity: 1; }
        
        /* СКРОЛЛБАРЫ */
        .sidebar-nav-card { scrollbar-width: thin; scrollbar-color: var(--accent-primary) transparent; }
        .sidebar-nav-card::-webkit-scrollbar { width: 4px; }
        .sidebar-nav-card::-webkit-scrollbar-track { background: transparent; }
        .sidebar-nav-card::-webkit-scrollbar-thumb { background: var(--accent-primary); border-radius: 10px; }
        .sidebar-nav-card::-webkit-scrollbar-thumb:hover { background: #601818; }

        html { scrollbar-width: thin; scrollbar-color: var(--accent-primary) transparent; }
        html::-webkit-scrollbar { width: 6px; }
        html::-webkit-scrollbar-track { background: transparent; }
        html::-webkit-scrollbar-thumb { background: var(--accent-primary); border-radius: 10px; }
        html::-webkit-scrollbar-thumb:hover { background: #601818; }

        /* АДАПТИВ */
        @media (max-width: 1000px) {
            .app-container { grid-template-columns: 1fr; gap: 0; }
            main { padding: 20px; padding-top: 0; }
            .mobile-header { display: flex; }
            .sidebar { 
                position: fixed; top: 0; left: 0; height: 100vh; padding: 20px;
                background: var(--bg-body); width: 320px; max-width: 85vw;
                transform: translateX(-100%); border-right: 1px solid rgba(0,0,0,0.05); z-index: 999;
            }
            .sidebar-brand-card { display: none; }
            .sidebar.open { transform: translateX(0); box-shadow: 20px 0 50px rgba(0,0,0,0.1); }
            .sidebar-overlay.open { display: block; opacity: 1; }
        }
        @media (max-width: 600px) { 
            .curtain-text { font-size: 1.8rem; padding: 0 20px; }
            .cookie-banner { flex-direction: column; text-align: center; gap: 12px; }
        }
    </style>
</head>
<body>

<div id="transition-curtain" class="page-curtain" transition:persist>
    <div class="curtain-text">ОПЕРА ГЛАЗАМИ ЧИТАТЕЛЯ</div>
</div>

<header class="mobile-header">
    <a href="/" class="mobile-logo">Читая Оперу</a>
    <button class="hamburger" id="menu-btn" aria-label="Открыть меню">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
</header>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<div class="app-container">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand-card">
            <a href="/" class="logo">ОПЕРА ГЛАЗАМИ<br>ЧИТАТЕЛЯ</a>
            <p class="slogan">Блог о либретто, смыслах и судьбах</p>
        </div>
        
        <nav class="sidebar-nav-card">
            <div class="nav-group-title">Навигация</div>
            <ul>
                <li><a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Главная</a></li>
                <li><a href="/about/" class={`nav-link ${currentPath.startsWith('/about') ? 'active' : ''}`}>О блоге</a></li>
                <li><a href="/contacts/" class={`nav-link ${currentPath.startsWith('/contacts') ? 'active' : ''}`}>Контакты</a></li>
                <li><a href="/glossary/" class={`nav-link ${currentPath.startsWith('/glossary') ? 'active' : ''}`}>Глоссарий</a></li>
            </ul>
            <br>
            <div class="nav-group-title">Рубрики</div>
            <ul>
                <li><a href="/librettists/" class={`nav-link ${currentPath.startsWith('/librettists') ? 'active' : ''}`}>Либреттисты</a></li>
                <li><a href="/opera-plots/" class={`nav-link ${currentPath.startsWith('/opera-plots') ? 'active' : ''}`}>Оперные сюжеты</a></li>
                <li><a href="/read/" class={`nav-link ${currentPath.startsWith('/read') ? 'active' : ''}`}>Что почитать</a></li>
                <li><a href="/listen/" class={`nav-link ${currentPath.startsWith('/listen') ? 'active' : ''}`}>Что послушать</a></li>
            </ul>
            <br>
            <div class="nav-group-title">Не только сюжеты</div>
            <ul>
                <li><a href="/history/" class={`nav-link ${currentPath.startsWith('/history') ? 'active' : ''}`}>История создания</a></li>
                <li><a href="/eternal-plots/" class={`nav-link ${currentPath.startsWith('/eternal-plots') ? 'active' : ''}`}>Вечные сюжеты</a></li>
                <li><a href="/book-to-opera/" class={`nav-link ${currentPath.startsWith('/book-to-opera') ? 'active' : ''}`}>Из книги в оперу</a></li>
                <li><a href="/censourship/" class={`nav-link ${currentPath.startsWith('/censourship') ? 'active' : ''}`}>Цензура и скандалы</a></li>
                <li><a href="/detective/" class={`nav-link ${currentPath.startsWith('/detective') ? 'active' : ''}`}>Оперный детектив</a></li>
                <li><a href="/librettology/" class={`nav-link ${currentPath.startsWith('/librettology') ? 'active' : ''}`}>Либреттология</a></li>
                <li><a href="/opera-world/" class={`nav-link ${currentPath.startsWith('/opera-world') ? 'active' : ''}`}>Оперный мир</a></li>
            </ul>
        </nav>
    </aside>

    <main>
        <slot />
    </main>
</div>

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-main">
            <div class="footer-brand">
                <a href="/" class="footer-logo">Опера глазами читателя</a>
                <p class="footer-slogan">Блог о либретто, смыслах и судьбах</p>
            </div>

            <div class="footer-contacts">
                {settings?.contactEmail && (
                    <a href={`mailto:${settings.contactEmail}`} class="footer-email">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        {settings.contactEmail}
                    </a>
                )}
                {settings?.socialLinks && settings.socialLinks.length > 0 && (
                    <div class="footer-socials">
                        {settings.socialLinks.map((s: any) => (
                            <a href={s.url} target="_blank" rel="noopener noreferrer" class="footer-social-link">
                                {s.platform}
                            </a>
                        ))}
                    </div>
                )}
            </div>

            {settings?.footerLinks && settings.footerLinks.length > 0 && (
                <nav class="footer-nav">
                    {settings.footerLinks.map((link: any) => (
                        <a href={link.url} class="footer-nav-link">{link.label}</a>
                    ))}
                </nav>
            )}
        </div>

        <div class="footer-divider"></div>

        <div class="footer-bottom">
            <p class="footer-copy">{settings?.footerText || '© 2025 Читая Оперу. Все права защищены.'}</p>
        </div>
    </div>
</footer>

<div class="cookie-banner" id="cookie-banner">
    <p>{settings?.cookieText || 'Мы используем cookies для улучшения работы сайта.'}</p>
    <button class="cookie-btn" id="cookie-accept">Принять</button>
</div>

<script is:inline>
    // ШТОРКА
    const ANIM_SPEED = 600; const EASING = 'cubic-bezier(0.45, 0, 0.55, 1)'; 
    function resetCurtain() { const c = document.getElementById('transition-curtain'); if(c){ c.style.transition='none'; c.style.transform='translateY(100%)'; c.classList.remove('visible'); } }
    document.addEventListener('astro:before-preparation', (ev) => { const c = document.getElementById('transition-curtain'); if(!c) return; const ol = ev.loader; ev.loader = async () => { c.style.transition='none'; c.style.transform='translateY(100%)'; await new Promise(r => requestAnimationFrame(r)); c.style.transition=`transform ${ANIM_SPEED}ms ${EASING}`; c.style.transform='translateY(0%)'; c.classList.add('visible'); await new Promise(r => setTimeout(r, ANIM_SPEED)); await ol(); }; });
    document.addEventListener('astro:after-swap', () => { const c = document.getElementById('transition-curtain'); if(!c) return; setTimeout(() => { c.style.transition=`transform ${ANIM_SPEED}ms ${EASING}`; c.style.transform='translateY(-100%)'; setTimeout(resetCurtain, ANIM_SPEED); }, 100); });
    resetCurtain();

    // МЕНЮ
    function initLayoutScripts() {
        const btn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        if(btn && sidebar && overlay) {
            function closeMenu() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }
            btn.addEventListener('click', () => { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; });
            overlay.addEventListener('click', closeMenu);
            sidebar.querySelectorAll('.nav-link').forEach(link => link.addEventListener('click', closeMenu));
        }
    }
    document.addEventListener('DOMContentLoaded', initLayoutScripts);
    document.addEventListener('astro:page-load', initLayoutScripts);

    // КУКИ
    function initCookies() {
        const banner = document.getElementById('cookie-banner');
        const btn = document.getElementById('cookie-accept');
        if (!banner || !btn) return;
        if (localStorage.getItem('cookies-accepted')) return;
        setTimeout(() => banner.classList.add('visible'), 1000);
        btn.addEventListener('click', () => {
            localStorage.setItem('cookies-accepted', '1');
            banner.classList.remove('visible');
        });
    }
    document.addEventListener('DOMContentLoaded', initCookies);
    document.addEventListener('astro:page-load', initCookies);
</script>
<button class="scroll-top" id="scroll-top" aria-label="Наверх">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 15l-6-6-6 6"/>
    </svg>
</button>
</body>
</html>