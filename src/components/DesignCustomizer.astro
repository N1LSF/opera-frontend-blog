---
// DesignCustomizer.astro
---
<div class="customizer-widget" id="customizer">
    <button class="customizer-toggle" id="customizer-toggle" aria-label="Настройки дизайна">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
    </button>
    
    <div class="customizer-panel">
        <h3 class="customizer-title">Настройки Оперы</h3>

        <div class="customizer-group">
            <label>Акцентный цвет:</label>
            <div class="color-options" id="color-picker">
                <!-- Бордовый (по умолчанию) -->
                <button class="color-btn active" data-color="#802525" style="background: #802525;" aria-label="Бордовый"></button>
                <!-- Золотой -->
                <button class="color-btn" data-color="#C29B57" style="background: #C29B57;" aria-label="Золотой"></button>
                <!-- Темно-синий -->
                <button class="color-btn" data-color="#1A2B3C" style="background: #1A2B3C;" aria-label="Темно-синий"></button>
                <!-- Угольный -->
                <button class="color-btn" data-color="#2C2C2C" style="background: #2C2C2C;" aria-label="Угольный"></button>
            </div>
        </div>

        <p class="customizer-note">Выберите настройки, погуляйте по сайту. Когда определитесь — напишите мне!</p>
    </div>
</div>

<style>
    .customizer-widget { position: fixed; bottom: 30px; right: 30px; z-index: 99999; font-family: var(--font-body); }
    .customizer-toggle { 
        width: 56px; height: 56px; border-radius: 50%; background: #fff; border: none; 
        box-shadow: 0 4px 20px rgba(0,0,0,0.1); cursor: pointer; color: var(--accent-primary); 
        display: flex; align-items: center; justify-content: center; transition: 0.3s; 
    }
    .customizer-toggle:hover { transform: scale(1.05); box-shadow: 0 6px 25px rgba(0,0,0,0.15); }
    
    .customizer-panel { 
        position: absolute; bottom: 70px; right: 0; width: 300px; background: #fff; 
        border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); padding: 25px; 
        opacity: 0; visibility: hidden; transform: translateY(20px); 
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); pointer-events: none; 
    }
    .customizer-widget.open .customizer-panel { opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
    
    .customizer-title { font-family: var(--font-head); font-size: 1.3rem; color: var(--accent-primary); margin-bottom: 25px; margin-top: 0; }
    
    .customizer-group { margin-bottom: 20px; }
    .customizer-group label { display: block; font-size: 0.95rem; color: #6E6E73; margin-bottom: 12px; font-weight: 500; }
    
    .color-options { display: flex; gap: 12px; }
    .color-btn { 
        width: 36px; height: 36px; border-radius: 50%; border: 2px solid transparent; 
        cursor: pointer; transition: 0.2s; padding: 0; 
    }
    .color-btn.active { box-shadow: 0 0 0 3px #fff, 0 0 0 5px rgba(0,0,0,0.1); transform: scale(1.1); }
    
    .customizer-note { font-size: 0.85rem; color: #888; margin-top: 25px; padding-top: 20px; border-top: 1px solid #eee; line-height: 1.5; }

    @media (max-width: 768px) {
        .customizer-widget { bottom: 20px; right: 20px; }
        .customizer-panel { right: -10px; width: 280px; }
    }
</style>

<script is:inline>
    function initDesignCustomizer() {
        const widget = document.getElementById('customizer');
        const toggle = document.getElementById('customizer-toggle');
        const colorBtns = document.querySelectorAll('.color-btn');

        if (!widget || !toggle) return;

        // Открытие/закрытие панели
        toggle.addEventListener('click', (e) => {
            e.stopPropagation();
            widget.classList.toggle('open');
        });

        // Закрытие при клике мимо
        document.addEventListener('click', (e) => {
            if (!widget.contains(e.target)) {
                widget.classList.remove('open');
            }
        });

        // Логика выбора цвета
        colorBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const color = btn.getAttribute('data-color');
                
                // Меняем цвет
                document.documentElement.style.setProperty('--accent-primary', color);
                localStorage.setItem('theme-accent-color', color);
                
                // Переключаем активный класс
                colorBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Восстановление цвета при загрузке страницы
        const savedColor = localStorage.getItem('theme-accent-color');
        if (savedColor) {
            document.documentElement.style.setProperty('--accent-primary', savedColor);
            colorBtns.forEach(btn => {
                if (btn.getAttribute('data-color') === savedColor) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        }
    }

    // Инициализация при первой загрузке и при переходах (ViewTransitions)
    document.addEventListener('DOMContentLoaded', initDesignCustomizer);
    document.addEventListener('astro:after-swap', initDesignCustomizer);
</script>