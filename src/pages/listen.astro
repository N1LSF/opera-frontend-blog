---
import { sanityClient, urlFor } from '../lib/sanity';
import MainLayout from '../layouts/MainLayout.astro';

const posts = await sanityClient.fetch(`*[_type == "post" && !(_id in path("drafts.**")) && (
  category->slug.current == "chto-poslushat" ||
  "chto-poslushat" in categories[]->slug.current
)] | order(publishedAt desc) {
  title, slug, mainImage, "composerName": composer->name, "countryName": country->title, "eraTitle": era->title
}`);
---

<MainLayout title="Что послушать">
    <main class="content">
        <div class="page-header">
            <h1 class="page-title">Что послушать</h1>
            <p class="page-subtitle">Записи и постановки, которые стоит услышать.</p>
        </div>
        {posts && posts.length > 0 ? (
            <div class="plots-grid">
                {posts.map((post) => (
                    <article class="plot-card">
                        <a href={`/blog/${post.slug?.current || '#'}/`}>
                            {post.mainImage ? (
                                <img class="plot-img" src={urlFor(post.mainImage).width(600).height(400).auto('format').url()} alt={post.title} loading="lazy" />
                            ) : (
                                <div class="plot-img" style="background: #eee;"></div>
                            )}
                            <div class="plot-info">
                                <h2 class="plot-title">{post.title}</h2>
                                <div class="plot-tags">
                                    {post.composerName && <span>{post.composerName}</span>}
                                    {post.countryName && <span>{post.countryName}</span>}
                                    {post.eraTitle && <span>{post.eraTitle}</span>}
                                </div>
                            </div>
                        </a>
                    </article>
                ))}
            </div>
        ) : (
            <div class="no-posts-container">
                <p class="no-posts">В этой рубрике пока нет статей.</p>
            </div>
        )}
    </main>
</MainLayout>

<style>
    .content { padding: 40px 60px; }
    .page-header { margin-bottom: 40px; }
    .page-title { font-family: var(--font-head); font-size: 2.5rem; margin-bottom: 15px; }
    .page-subtitle { color: var(--text-muted); }
    .plots-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; }
    .plot-card { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft); transition: 0.3s; }
    .plot-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
    .plot-img { width: 100%; height: 200px; object-fit: cover; }
    .plot-info { padding: 24px; }
    .plot-title { font-family: var(--font-head); font-size: 1.2rem; margin-bottom: 12px; color: var(--text-main); transition: 0.2s; }
    .plot-card:hover .plot-title { color: var(--accent-primary); }
    .plot-tags { font-size: 0.8rem; color: var(--accent-primary); font-weight: 500; display: flex; flex-wrap: wrap; gap: 8px; }
    .plot-tags span { background: var(--accent-light); padding: 4px 10px; border-radius: 50px; }
    .no-posts-container { background: #fff; padding: 40px; border-radius: var(--radius-lg); text-align: center; border: 1px dashed #ccc; }
    .no-posts { font-size: 1.2rem; color: var(--text-muted); font-weight: 500; }
    @media (max-width: 768px) {
        .content { padding: 20px 15px; }
        .page-header { margin-bottom: 25px; }
        .page-title { font-size: 2rem; margin-bottom: 10px; }
        .plots-grid { grid-template-columns: 1fr; gap: 20px; }
        .plot-info { padding: 20px; }
        .plot-title { font-size: 1.3rem; }
    }
</style>